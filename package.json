{
  "name": "minicharles",
  "version": "0.1.0",
  "description": "Outlook email auto-sorter & summarizer powered by Claude",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "auth": "tsx src/cli/auth.ts",
    "test-connection": "tsx src/cli/test-connection.ts",
    "bot": "tsx src/cli/bot.ts",
    "send-summary": "tsx src/cli/send-summary.ts",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
